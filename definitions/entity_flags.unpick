unpick v4

group int entity_flag_index
	net.minecraft.world.entity.Entity.FLAG_ONFIRE
	net.minecraft.world.entity.Entity.FLAG_SHIFT_KEY_DOWN
	net.minecraft.world.entity.Entity.FLAG_SPRINTING
	net.minecraft.world.entity.Entity.FLAG_SWIMMING
	net.minecraft.world.entity.Entity.FLAG_INVISIBLE
	net.minecraft.world.entity.Entity.FLAG_GLOWING
	net.minecraft.world.entity.Entity.FLAG_FALL_FLYING

target_annotation net.minecraft.world.entity.Entity$Flags entity_flag_index


group int living_entity_flags
	@flags
	net.minecraft.world.entity.LivingEntity.LIVING_ENTITY_FLAG_IS_USING
	net.minecraft.world.entity.LivingEntity.LIVING_ENTITY_FLAG_OFF_HAND
	net.minecraft.world.entity.LivingEntity.LIVING_ENTITY_FLAG_SPIN_ATTACK

target_method net.minecraft.world.entity.LivingEntity setLivingEntityFlag (IZ)V
	param 0 living_entity_flags


group int bee_flags
	@flags
	net.minecraft.world.entity.animal.bee.Bee.FLAG_ROLL
	net.minecraft.world.entity.animal.bee.Bee.FLAG_HAS_STUNG
	net.minecraft.world.entity.animal.bee.Bee.FLAG_HAS_NECTAR

target_method net.minecraft.world.entity.animal.bee.Bee getFlag (I)Z
	param 0 bee_flags
target_method net.minecraft.world.entity.animal.bee.Bee setFlag (IZ)V
	param 0 bee_flags


group int fox_flags
	@flags
	net.minecraft.world.entity.animal.fox.Fox.FLAG_SITTING
	net.minecraft.world.entity.animal.fox.Fox.FLAG_CROUCHING
	net.minecraft.world.entity.animal.fox.Fox.FLAG_INTERESTED
	net.minecraft.world.entity.animal.fox.Fox.FLAG_POUNCING
	net.minecraft.world.entity.animal.fox.Fox.FLAG_SLEEPING
	net.minecraft.world.entity.animal.fox.Fox.FLAG_FACEPLANTED
	net.minecraft.world.entity.animal.fox.Fox.FLAG_DEFENDING

target_method net.minecraft.world.entity.animal.fox.Fox getFlag (I)Z
	param 0 fox_flags
target_method net.minecraft.world.entity.animal.fox.Fox setFlag (IZ)V
	param 0 fox_flags


