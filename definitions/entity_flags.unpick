	@flags
	net.minecraft.world.entity.animal.equine.AbstractHorse.FLAG_TAME
	net.minecraft.world.entity.animal.equine.AbstractHorse.FLAG_BRED
	net.minecraft.world.entity.animal.equine.AbstractHorse.FLAG_EATING
	net.minecraft.world.entity.animal.equine.AbstractHorse.FLAG_STANDING
	net.minecraft.world.entity.animal.equine.AbstractHorse.FLAG_OPEN_MOUTH

target_method net.minecraft.world.entity.animal.equine.AbstractHorse getFlag (I)Z
	param 0 horse_flags
target_method net.minecraft.world.entity.animal.equine.AbstractHorse setFlag (IZ)V
	param 0 horse_flags


group int panda_flags
	@flags
	net.minecraft.world.entity.animal.panda.Panda.FLAG_SNEEZE
	net.minecraft.world.entity.animal.panda.Panda.FLAG_ROLL
	net.minecraft.world.entity.animal.panda.Panda.FLAG_SIT
	net.minecraft.world.entity.animal.panda.Panda.FLAG_ON_BACK

target_method net.minecraft.world.entity.animal.panda.Panda getFlag (I)Z
	param 0 panda_flags
target_method net.minecraft.world.entity.animal.panda.Panda setFlag (IZ)V
	param 0 panda_flags


group int arrow_flags
	@flags
	net.minecraft.world.entity.projectile.arrow.AbstractArrow.FLAG_CRIT
	net.minecraft.world.entity.projectile.arrow.AbstractArrow.FLAG_NOPHYSICS

target_method net.minecraft.world.entity.projectile.arrow.AbstractArrow setFlag (IZ)V
	param 0 arrow_flags


group int vex_flags
	net.minecraft.world.entity.monster.Vex.FLAG_IS_CHARGING

target_method net.minecraft.world.entity.monster.Vex getVexFlag (I)Z
	param 0 vex_flags
target_method net.minecraft.world.entity.monster.Vex setVexFlag (IZ)V
	param 0 vex_flags


group int armor_stand_flags
	@flags
	net.minecraft.world.entity.decoration.ArmorStand.CLIENT_FLAG_SMALL
	net.minecraft.world.entity.decoration.ArmorStand.CLIENT_FLAG_SHOW_ARMS
	net.minecraft.world.entity.decoration.ArmorStand.CLIENT_FLAG_NO_BASEPLATE
	net.minecraft.world.entity.decoration.ArmorStand.CLIENT_FLAG_MARKER

target_method net.minecraft.world.entity.decoration.ArmorStand setBit (BIZ)B
	param 1 armor_stand_flags


group int text_display_flags
	@flags
	net.minecraft.world.entity.Display$TextDisplay.FLAG_SHADOW
	net.minecraft.world.entity.Display$TextDisplay.FLAG_SEE_THROUGH
	net.minecraft.world.entity.Display$TextDisplay.FLAG_USE_DEFAULT_BACKGROUND
	net.minecraft.world.entity.Display$TextDisplay.FLAG_ALIGN_LEFT
	net.minecraft.world.entity.Display$TextDisplay.FLAG_ALIGN_RIGHT

target_method net.minecraft.world.entity.Display$TextDisplay loadFlag (BLnet/minecraft/world/level/storage/ValueInput;Ljava/lang/String;B)B
	param 3 text_display_flags
target_method net.minecraft.world.entity.Display$TextDisplay storeFlag (BLnet/minecraft/world/level/storage/ValueOutput;Ljava/lang/String;B)V
	param 3 text_display_flags
target_method net.minecraft.world.entity.Display$TextDisplay getAlign (B)Lnet/minecraft/world/entity/Display$TextDisplay$Align;
	param 0 text_display_flags
target_method net.minecraft.world.entity.Display$TextDisplay setFlags (B)V
	param 0 text_display_flags
target_method net.minecraft.world.entity.Display$TextDisplay getFlags ()B
	return text_display_flags
target_method net.minecraft.world.entity.Display$TextDisplay$TextRenderState flags ()B
	return text_display_flags

# mob, bat, snow golem, flags are directly on method bodies

group int pufferfish_state
	@scope method net.minecraft.world.entity.animal.fish.Pufferfish tick ()V # getter got replaced in touch/playerTouch...
	net.minecraft.world.entity.animal.fish.Pufferfish.STATE_SMALL
	net.minecraft.world.entity.animal.fish.Pufferfish.STATE_MID
	net.minecraft.world.entity.animal.fish.Pufferfish.STATE_FULL

target_method net.minecraft.world.entity.animal.fish.Pufferfish setPuffState (I)V
	param 0 pufferfish_state
target_method net.minecraft.world.entity.animal.fish.Pufferfish getPuffState ()I
	return pufferfish_state
target_method net.minecraft.world.entity.animal.fish.Pufferfish getScale (I)F
	param 0 pufferfish_state
