unpick v4

group int
	@scope class net.minecraft.util.StringDecomposer
	net.minecraft.util.StringDecomposer.REPLACEMENT_CHAR

group int cursor3d_type
	net.minecraft.core.Cursor3D.TYPE_INSIDE
	net.minecraft.core.Cursor3D.TYPE_FACE
	net.minecraft.core.Cursor3D.TYPE_EDGE
	net.minecraft.core.Cursor3D.TYPE_CORNER

target_method net.minecraft.core.Cursor3D getNextType ()I
	return cursor3d_type
