unpick v4

group int chain_modifier_flags
	@flags
	net.minecraft.commands.execution.ChainModifiers.FLAG_FORKED
	net.minecraft.commands.execution.ChainModifiers.FLAG_IS_RETURN

target_field net.minecraft.commands.execution.ChainModifiers flags B chain_modifier_flags
target_method net.minecraft.commands.execution.ChainModifiers setFlag (B)Lnet/minecraft/commands/execution/ChainModifiers;
	param 0 chain_modifier_flags

group int number_argument_flags
	@flags
	net.minecraft.commands.synchronization.ArgumentUtils.NUMBER_FLAG_MIN
	net.minecraft.commands.synchronization.ArgumentUtils.NUMBER_FLAG_MAX

target_method net.minecraft.commands.synchronization.ArgumentUtils createNumberFlags (ZZ)I
	return number_argument_flags
target_method net.minecraft.commands.synchronization.ArgumentUtils numberHasMin (B)Z
	param 0 number_argument_flags
target_method net.minecraft.commands.synchronization.ArgumentUtils numberHasMax (B)Z
	param 0 number_argument_flags

